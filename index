<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mental Health Coach AI</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #f0f8ff; }
    header { background: #4CAF50; color: white; padding: 1rem; text-align: center; }
    nav { display: flex; justify-content: center; margin: 1rem 0; gap: 1rem; }
    nav button { padding: 0.5rem 1rem; cursor: pointer; }
    section { display: none; padding: 1rem; max-width: 800px; margin: auto; }
    section.active { display: block; }
    h2 { color: #333; }
    iframe { width: 100%; height: 400px; }
  </style>
</head>
<body>

<header>
  <h1>Mental Health Coach AI</h1>
</header>

<nav>
  <button onclick="showSection('songs')">Songs</button>
  <button onclick="showSection('funny')">Funny Videos</button>
  <button onclick="showSection('meditation')">Meditation</button>
  <button onclick="showSection('yoga')">Yoga</button>
</nav>

<section id="songs">
  <h2>Relaxing Songs</h2>
  <iframe src="https://www.youtube.com/embed/2OEL4P1Rz04" title="Relaxing Song"></iframe>
</section>

<section id="funny">
  <h2>Funny Videos</h2>
  <iframe src="https://www.youtube.com/embed/J---aiyznGQ" title="Funny Video"></iframe>
</section>

<section id="meditation">
  <h2>Guided Meditation</h2>
  <iframe src="https://www.youtube.com/embed/inpok4MKVLM" title="Meditation Video"></iframe>
</section>

<section id="yoga">
  <h2>Yoga for Mental Health</h2>
  <iframe src="https://www.youtube.com/embed/v7AYKMP6rOE" title="Yoga Video"></iframe>
</section>

<script>
  function showSection(id) {
    document.querySelectorAll('section').forEach(sec => sec.classList.remove('active'));
    document.getElementById(id).classList.add('active');
  }
  // Show first section by default
  showSection('songs');
</script>

</body>
</html>
